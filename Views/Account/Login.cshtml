@model GestionBibliotheque.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Bibliotheque</title>
    <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #0d2b4e, #1a4a7a, #2e6da4);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .login-container {
                background: white;
                border-radius: 12px;
                padding: 40px;
                width: 400px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            }
            .login-header { text-align: center; margin-bottom: 30px; }
            .login-header h1 { color: #0d2b4e; font-size: 26px; margin-bottom: 5px; }
            .login-header p { color: #6c8ebf; font-size: 14px; }
            .form-group { margin-bottom: 20px; }
            .form-group label { display: block; color: #0d2b4e; font-weight: 600; margin-bottom: 6px; font-size: 14px; }
            .form-group input {
                width: 100%; padding: 12px 15px; border: 2px solid #c8d8e8;
                border-radius: 8px; font-size: 14px; transition: border-color 0.3s; outline: none;
            }
            .form-group input:focus { border-color: #2e6da4; }
            .btn-login {
                width: 100%; padding: 13px;
                background: linear-gradient(135deg, #0d2b4e, #2e6da4);
                color: white; border: none; border-radius: 8px;
                font-size: 16px; font-weight: 600; cursor: pointer;
            }
            .btn-login:hover { opacity: 0.9; }
            .btn-inscription {
                width: 100%; padding: 13px; margin-top: 12px;
                background: white; color: #2e6da4;
                border: 2px solid #2e6da4; border-radius: 8px;
                font-size: 15px; font-weight: 600; cursor: pointer;
                text-align: center; text-decoration: none; display: block;
            }
            .btn-inscription:hover { background: #f0f4f8; }
            .separateur {
                text-align: center; margin: 15px 0;
                color: #aaa; font-size: 13px; position: relative;
            }
            .separateur::before, .separateur::after {
                content: ""; position: absolute; top: 50%;
                width: 40%; height: 1px; background: #ddd;
            }
            .separateur::before { left: 0; }
            .separateur::after { right: 0; }
            .erreur {
                background: #ffe0e0; color: #c0392b;
                padding: 10px 15px; border-radius: 8px;
                margin-bottom: 20px; font-size: 14px; text-align: center;
            }
            .succes {
                background: #d5f5e3; color: #27ae60;
                padding: 10px 15px; border-radius: 8px;
                margin-bottom: 20px; font-size: 14px; text-align: center;
            }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h1>Bibliotheque</h1>
            <p>Connectez-vous a votre compte</p>
        </div>

        @if (TempData["Succes"] != null)
        {
            <div class="succes">@TempData["Succes"]</div>
        }
        @if (ViewBag.Erreur != null)
        {
            <div class="erreur">@ViewBag.Erreur</div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" type="email" placeholder="votre@email.com" />
            </div>
            <div class="form-group">
                <label>Mot de passe</label>
                <input asp-for="Mot_de_passe" type="password" placeholder="Votre mot de passe" />
            </div>
            <button type="submit" class="btn-login">Se connecter</button>
        </form>

        <div class="separateur">ou</div>

        <a href="/Account/Inscription" class="btn-inscription">Creer un compte</a>
    </div>
</body>
</html>