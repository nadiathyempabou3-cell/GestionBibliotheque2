@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription - Bibliotheque</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0d2b4e, #1a4a7a, #2e6da4);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 0;
        }
        .inscription-container {
            background: white;
            border-radius: 12px;
            padding: 40px;
            width: 450px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .header { text-align: center; margin-bottom: 30px; }
        .header h1 { color: #0d2b4e; font-size: 24px; margin-bottom: 5px; }
        .header p { color: #6c8ebf; font-size: 14px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; color: #0d2b4e; font-weight: 600; margin-bottom: 6px; font-size: 14px; }
        .form-group input {
            width: 100%; padding: 11px 14px; border: 2px solid #c8d8e8;
            border-radius: 8px; font-size: 14px; outline: none;
        }
        .form-group input:focus { border-color: #2e6da4; }
        .btn-inscrire {
            width: 100%; padding: 13px;
            background: linear-gradient(135deg, #0d2b4e, #2e6da4);
            color: white; border: none; border-radius: 8px;
            font-size: 15px; font-weight: 600; cursor: pointer;
        }
        .btn-inscrire:hover { opacity: 0.9; }
        .lien-login {
            text-align: center; margin-top: 15px; font-size: 14px; color: #666;
        }
        .lien-login a { color: #2e6da4; font-weight: 600; text-decoration: none; }
        .lien-login a:hover { text-decoration: underline; }
        .erreur {
            background: #ffe0e0; color: #c0392b;
            padding: 10px 15px; border-radius: 8px;
            margin-bottom: 20px; font-size: 14px; text-align: center;
        }
    </style>
</head>
<body>
    <div class="inscription-container">
        <div class="header">
            <h1>Creer un compte</h1>
            <p>Rejoignez la bibliotheque</p>
        </div>

        @if (ViewBag.Erreur != null)
        {
            <div class="erreur">@ViewBag.Erreur</div>
        }

        <form action="/Account/Inscription" method="post">
            <div class="form-row">
                <div class="form-group">
                    <label>Nom</label>
                    <input type="text" name="nom" placeholder="Votre nom" required />
                </div>
                <div class="form-group">
                    <label>Prenom</label>
                    <input type="text" name="prenom" placeholder="Votre prenom" required />
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="votre@email.com" required />
            </div>
            <div class="form-group">
                <label>Mot de passe</label>
                <input type="password" name="mot_de_passe" placeholder="Choisissez un mot de passe" required />
            </div>
            <div class="form-group">
                <label>Telephone</label>
                <input type="text" name="telephone" placeholder="Votre numero de telephone" />
            </div>
            <div class="form-group">
                <label>Adresse</label>
                <input type="text" name="adresse" placeholder="Votre adresse" />
            </div>
            <button type="submit" class="btn-inscrire">Creer mon compte</button>
        </form>

        <div class="lien-login">
            Vous avez deja un compte ? <a href="/Account/Login">Se connecter</a>
        </div>
    </div>
</body>
</html>