@model List<GestionBibliotheque.Models.Emprunt>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Emprunts - Bibliotheque</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f4f8; display: flex; min-height: 100vh; }
        .sidebar { width: 250px; background: linear-gradient(180deg, #0d2b4e, #1a4a7a); color: white; padding: 20px 0; position: fixed; height: 100vh; }
        .sidebar-header { text-align: center; padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px; }
        .sidebar-header h2 { font-size: 20px; color: #a8c8e8; }
        .sidebar-menu a { display: block; padding: 12px 25px; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 14px; border-left: 3px solid transparent; }
        .sidebar-menu a:hover, .sidebar-menu a.active { background: rgba(255,255,255,0.1); color: white; border-left-color: #a8c8e8; }
        .sidebar-menu .menu-titre { padding: 10px 25px; font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-top: 10px; }
        .main-content { margin-left: 250px; flex: 1; padding: 30px; }
        .top-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .top-header h1 { color: #0d2b4e; font-size: 24px; }
        .btn { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; text-decoration: none; font-size: 13px; font-weight: 600; }
        .btn-primary { background: #2e6da4; color: white; }
        .btn-success { background: #27ae60; color: white; }
        .btn-danger { background: #c0392b; color: white; }
        .btn:hover { opacity: 0.85; }
        .alert-succes { background: #d5f5e3; color: #27ae60; padding: 12px 20px; border-radius: 8px; margin-bottom: 20px; }
        .alert-erreur { background: #ffe0e0; color: #c0392b; padding: 12px 20px; border-radius: 8px; margin-bottom: 20px; }
        .table-card { background: white; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); overflow: hidden; }
        table { width: 100%; border-collapse: collapse; }
        thead { background: linear-gradient(135deg, #0d2b4e, #2e6da4); color: white; }
        th { padding: 15px; text-align: left; font-size: 13px; }
        td { padding: 13px 15px; border-bottom: 1px solid #eef2f7; font-size: 13px; color: #333; }
        tr:hover { background: #f8fbff; }
        .badge { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-encours { background: #fff3cd; color: #e67e22; }
        .badge-retourne { background: #d5f5e3; color: #27ae60; }
        .badge-retard { background: #ffe0e0; color: #c0392b; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header"><h2>Bibliotheque</h2></div>
        <div class="sidebar-menu">
            <div class="menu-titre">Navigation</div>
            <a href="/Dashboard/Index">Tableau de bord</a>
            <div class="menu-titre">Catalogue</div>
            <a href="/Livre/Index">Livres</a>
            <a href="/Categorie/Index">Categories</a>
            <div class="menu-titre">Gestion</div>
            <a href="/Emprunt/Index" class="active">Emprunts</a>
            <a href="/Reservation/Index">Reservations</a>
            <a href="/Membre/Index">Membres</a>
            <a href="/Abonnement/Index">Abonnements</a>
            <a href="/Penalite/Index">Penalites</a>
            <div class="menu-titre">Compte</div>
            <a href="/Account/Logout">Se deconnecter</a>
        </div>
    </div>

    <div class="main-content">
        <div class="top-header">
            <h1>Gestion des Emprunts</h1>
            <a href="/Emprunt/Ajouter" class="btn btn-primary">+ Nouvel emprunt</a>
        </div>

        @if (TempData["Succes"] != null)
        { <div class="alert-succes">@TempData["Succes"]</div> }
        @if (TempData["Erreur"] != null)
        { <div class="alert-erreur">@TempData["Erreur"]</div> }

        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Membre</th>
                        <th>Livre</th>
                        <th>Date Emprunt</th>
                        <th>Retour Prevu</th>
                        <th>Retour Effectif</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emprunt in Model)
                    {
                        <tr>
                            <td><strong>@emprunt.Membre.Utilisateur.Prenom @emprunt.Membre.Utilisateur.Nom</strong></td>
                            <td>@emprunt.Livre.Titre</td>
                            <td>@emprunt.Date_emprunt.ToString("dd/MM/yyyy")</td>
                            <td>@emprunt.Date_retour_prevue.ToString("dd/MM/yyyy")</td>
                            <td>@(emprunt.Date_retour_effective.HasValue ? emprunt.Date_retour_effective.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td>
                                <span class="badge @(emprunt.Statut_emprunt == "en_cours" ? "badge-encours" : emprunt.Statut_emprunt == "retourné" ? "badge-retourne" : "badge-retard")">
                                    @emprunt.Statut_emprunt
                                </span>
                            </td>
                            <td>
                                @if (emprunt.Statut_emprunt == "en_cours")
                                {
                                    <a href="/Emprunt/Retourner/@emprunt.Id_emprunt" class="btn btn-success"
                                       onclick="return confirm('Confirmer le retour ?')">Retourner</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>